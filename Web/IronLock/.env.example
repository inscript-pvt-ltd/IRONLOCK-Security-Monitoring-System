APP_NAME="IronLock Security Monitoring"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# === MySQL Database (all business data + authentication) ===
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ironlock
DB_USERNAME=root
DB_PASSWORD=

# === Firebase (Cloud Messaging / FCM ONLY) ===
# Authentication is entirely MySQL/Laravel — Firebase is NOT used for auth.
FIREBASE_PROJECT=ironlock
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CREDENTIALS=storage/app/firebase/ironlock-firebase-adminsdk.json

# === Session, Cache, Queue (MySQL-backed) ===
SESSION_DRIVER=database
SESSION_LIFETIME=120
CACHE_STORE=database
QUEUE_CONNECTION=database

# === File Storage (local server, UK region) ===
FILESYSTEM_DISK=local
IRONLOCK_PHOTOS_DISK=local
IRONLOCK_PHOTOS_PATH=private/photos
IRONLOCK_REPORTS_PATH=private/reports

# Mail Configuration (optional - for admin notifications)
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@ironlock.co.uk
MAIL_FROM_NAME="${APP_NAME}"

# === WebSocket Broadcasting (Laravel Echo with Pusher) ===
BROADCAST_CONNECTION=pusher
PUSHER_APP_ID=your_pusher_app_id
PUSHER_APP_KEY=your_pusher_key
PUSHER_APP_SECRET=your_pusher_secret
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=eu

# === IronLock Specific Configuration ===
IRONLOCK_PHOTO_NONCE_EXPIRY_ONLINE=60
IRONLOCK_PHOTO_NONCE_EXPIRY_OFFLINE=900
IRONLOCK_GPS_PING_INTERVAL=15
IRONLOCK_WAKEFULNESS_MIN_INTERVAL=1800
IRONLOCK_WAKEFULNESS_MAX_INTERVAL=2700
IRONLOCK_GRACE_PERIOD_MINUTES=5

VITE_APP_NAME="${APP_NAME}"
